# Optional environment variables for cloud providers.
# Keep values empty in git; set real values only in your local `.env`.

OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Optional local Ollama overrides (leave empty to use configs/config.yaml defaults; default model is llama3.1:8b)
OLLAMA_MODEL=
OLLAMA_MAX_NEW_TOKENS=
OLLAMA_TEMPERATURE=
OLLAMA_TOP_P=
OLLAMA_DO_SAMPLE=
OLLAMA_FALLBACK_TO_DUMMY=
OLLAMA_NUM_CTX=
OLLAMA_TIMEOUT_SECONDS=

# UI toggle default (true/false). If empty: false locally (Ollama), true on Streamlit Cloud (dummy).
USE_DUMMY_GENERATOR=
