# Interim IP demo (no domain): Caddy-managed self-signed TLS on :443.
# In .env: CADDYFILE=./Caddyfile.ip
# Generate auth: ./deploy/generate-caddy-auth.sh demo 'your-password'

{
	auto_https off
}

:443 {
	tls internal

	import /etc/caddy/caddy-basicauth.conf

	reverse_proxy app:8501 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}
