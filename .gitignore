# =====================================
# Python / Bytecode / Packaging
# =====================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# =====================================
# Virtual environments & secrets
# =====================================
.env
.env.local
.env.*
!.env.example
deploy/caddy-basicauth.conf
deploy/certs/
.venv
venv/
ENV/

# =====================================
# Streamlit configuration & secrets
# =====================================
.streamlit/secrets.toml
.streamlit/config.toml  # only if it contains secrets/keys
# Ignore project-level Streamlit folder (themes, local config).streamlit/             

# =====================================
# Vector stores & embeddings (critical for RAG)
# =====================================
*.faiss                 # Local FAISS index files — large & regeneratable
*.index
index.faiss
index.pkl
chroma/                 # If/when using Chroma as alternative
*.chroma

# =====================================
# Data & test files (don't commit client PDFs or large samples)
# =====================================
data/
samples/
uploaded/
*.pdf                   # Optional: comment out if you want to include small demo PDFs

# =====================================
# Hugging Face / model caches
# =====================================
.huggingface/
.cache/huggingface/

# =====================================
# Editor-specific — track rules, agents, commands; ignore rest of .cursor/
# =====================================
.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/agents/
!.cursor/agents/**
!.cursor/commands/
!.cursor/commands/**
.vscode/
.idea/

# =====================================
# Testing & linting caches (add later when you write tests)
# =====================================
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Private operator notes (sales / deployment — not for repo)
docs-private/

# OS / temp files
.DS_Store
Thumbs.db
*.log
tmp/
temp/
